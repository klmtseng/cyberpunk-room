{
  "name": "cyberpunk-room",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Cyberpunk 2077-style first-person room simulator. Browser-based, WebGPU/WebGL2, WebXR-ready.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "three": "^0.170.0",
    "postprocessing": "^6.36.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-rnd": "^10.4.13"
  },
  "devDependencies": {
    "@types/three": "^0.170.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@webgpu/types": "^0.1.52",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  },
  "allowScripts": {
    "esbuild@0.21.5": true
  }
}
